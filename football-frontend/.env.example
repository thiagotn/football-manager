# URL da API (embutida no build pelo Vite)
VITE_API_URL=http://localhost:8000/api/v1

# Dados do controlador legal — usados nas páginas /termos e /privacidade
# Preencher no .env local e nos GitHub Secrets (LEGAL_CONTROLLER_NAME, etc.)
PUBLIC_LEGAL_CONTROLLER_NAME=
PUBLIC_LEGAL_CONTROLLER_DOC=
PUBLIC_LEGAL_FORUM_CITY=
PUBLIC_LEGAL_CONTACT_EMAIL=

# Habilita fluxo de billing (Stripe). Em produção deixe false/ausente.
# Em desenvolvimento local, mude para true.
VITE_BILLING_ENABLED=false
