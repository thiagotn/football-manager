# Credenciais do Grafana (produção)
# Copie este arquivo para .env.monitoring e preencha os valores
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=troque-para-uma-senha-forte

# Basic Auth para Prometheus (gerada com htpasswd)
# Geração: htpasswd -nb admin suasenha
# Cole o hash completo abaixo (ex: admin:$apr1$xyz$hash...)
# ATENÇÃO: no traefik-dynamic.yml, troque MONITORING_AUTH_HASH por este valor
MONITORING_AUTH_HASH=admin:REPLACE_WITH_HTPASSWD_HASH
