#!/bin/bash
# Pre-push hook: check for security vulnerabilities in Python dependencies
# Run pip-audit before allowing push to inform about issues

set -e

echo "🔍 Running security audit before push..."
echo ""

cd football-api

# Check if poetry is available
if ! command -v poetry &> /dev/null; then
    echo "⚠️  Poetry not found. Skipping security audit."
    exit 0
fi

# Run pip-audit and capture output
AUDIT_OUTPUT=$(poetry run pip-audit --skip-editable 2>&1 || true)

# Check if there are any vulnerabilities (only in PyPI packages, not system packages)
if echo "$AUDIT_OUTPUT" | grep -q "Found [1-9] known vulnerabilities"; then
    echo "⚠️  Security vulnerabilities detected:"
    echo ""
    echo "$AUDIT_OUTPUT" | grep -E "^(Name|----|-)" | head -20
    echo ""
    echo "💡 To see full details and fix:"
    echo "   cd football-api && poetry run pip-audit"
    echo "   cd football-api && poetry update"
    echo ""
    echo "ℹ️  Continuing with push (CI will perform stricter checks)"
else
    echo "✅ No vulnerabilities in project dependencies!"
fi

exit 0
