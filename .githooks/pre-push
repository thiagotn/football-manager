#!/bin/bash
# Pre-push hook: check for security vulnerabilities in Python dependencies
# Run pip-audit before allowing push to inform about issues

set -e

echo "🔍 Running security audit before push..."
echo ""

cd football-api

# Check if poetry is available
if ! command -v poetry &> /dev/null; then
    echo "⚠️  Poetry not found. Skipping security audit."
    exit 0
fi

# Get poetry virtualenv path and audit only project dependencies
POETRY_VENV=$(poetry env info --path 2>/dev/null || echo "")
if [ -z "$POETRY_VENV" ]; then
    echo "⚠️  Could not find poetry virtualenv. Skipping security audit."
    exit 0
fi

# Run pip-audit against poetry virtualenv only
AUDIT_OUTPUT=$("$POETRY_VENV/bin/pip" audit --skip-editable 2>&1 || true)

# Check if there are any vulnerabilities (look for "Found X known vulnerabilities")
VULNERABILITY_COUNT=$(echo "$AUDIT_OUTPUT" | grep -oP "Found \K[0-9]+" || echo "0")

if [ "$VULNERABILITY_COUNT" -gt 0 ]; then
    echo "❌ Security vulnerabilities found!"
    echo ""
    echo "$AUDIT_OUTPUT" | grep -v "^Name" | head -50
    echo ""
    echo "💡 To fix, run:"
    echo "   cd football-api && poetry run pip-audit"
    echo "   cd football-api && poetry update"
    echo ""
    exit 1
else
    echo "✅ No vulnerabilities in project dependencies!"
    exit 0
fi
