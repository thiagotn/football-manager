# Application
APP_ENV=development
PORT=8080

# Database
DATABASE_URL=postgres://football:football@localhost:5433/football_dev?sslmode=disable

# JWT
SECRET_KEY=change-me-to-a-random-256-bit-secret

# Twilio Verify (OTP)
# Leave empty to use bypass mode (OTP code = "123456" for any number)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# Supabase Storage (avatar uploads)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Anthropic (AI chat)
ANTHROPIC_API_KEY=

# Stripe (subscriptions)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Web Push (VAPID)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
